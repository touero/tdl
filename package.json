{
  "name": "cloudflare-download-station",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n client,worker -c blue,green \"npm:dev:client\" \"npm:dev:worker\"",
    "dev:client": "vite",
    "dev:worker": "XDG_CONFIG_HOME=./.wrangler-config wrangler dev --local --port 8787",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "deploy": "npm run build && XDG_CONFIG_HOME=./.wrangler-config wrangler deploy"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260305.0",
    "@types/react": "^18.3.19",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3",
    "vite": "^6.2.2",
    "wrangler": "^4.72.0"
  }
}
